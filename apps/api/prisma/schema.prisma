// This is your Prisma schema file

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  username  String   @unique
  email     String   @unique
  password  String   // Encrypted
  role      String   // UserRole enum
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  ownedTasks      Task[]
  ownedWorkflows  Workflow[]
  ownedSchedules  Schedule[]
  ownedCalendars  Calendar[]
  ownedSecrets    Secret[]

  @@map("users")
}

model Secret {
  id          String   @id @default(uuid())
  name        String
  description String?
  value       String   // Encrypted
  scope       String   // ScopeType enum
  ownerId     String
  owner       User     @relation(fields: [ownerId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("secrets")
}

model Task {
  id          String   @id @default(uuid())
  name        String
  description String?
  scope       String   // ScopeType enum
  ownerId     String
  owner       User     @relation(fields: [ownerId], references: [id])
  
  // JSON fields for complex data
  command            Json    // HttpRequestConfig
  variableExtraction Json?   // VariableExtraction[]
  outputMutation     Json?   // OutputMutation
  statusMappings     Json?   // StatusMapping[]
  retryPolicy        Json?   // RetryPolicy
  sanityChecks      Json?   // SanityCheck[]
  
  icon      String?
  tags      String[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Folder Relation
  folderId   String?
  folder     TaskGroup? @relation(fields: [folderId], references: [id])

  // Relations
  executions TaskExecution[]

  @@map("tasks")
}

model TaskGroup {
  id          String   @id @default(uuid())
  name        String
  description String?
  
  // Recursive Hierarchy
  parentId    String?
  parent      TaskGroup? @relation("TaskGroupToTaskGroup", fields: [parentId], references: [id])
  children    TaskGroup[] @relation("TaskGroupToTaskGroup")

  tasks       Task[]   
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([name, parentId])
  @@map("task_groups")
}

model TaskExecution {
  id        String   @id @default(uuid())
  taskId    String?
  task      Task?    @relation(fields: [taskId], references: [id])
  
  nodeId    String?  // The ID of the node in the workflow graph
  
  workflowExecutionId String?
  workflowExecution   WorkflowExecution? @relation("WorkflowExecutionToTaskExecutions", fields: [workflowExecutionId], references: [id])
  
  subWorkflows WorkflowExecution[] @relation("TaskExecutionToSubWorkflow")

  status    String   // PENDING, RUNNING, COMPLETED, FAILED
  input     Json?    // HttpRequestConfig (actual sent)
  result    Json?    // HttpResponse
  error     String?
  startedAt DateTime @default(now())
  completedAt DateTime?
  duration  Int?     // milliseconds

  workerId  String?
  worker    Worker?  @relation(fields: [workerId], references: [id])
  
  targetWorkerId String?
  targetTags     String[]

  @@map("task_executions")
}

model Worker {
  id          String   @id @default(uuid())
  name        String?
  hostname    String   @unique
  ipAddress   String?
  status      String   @default("OFFLINE") // ONLINE, OFFLINE, DISABLED
  tags        String[]
  lastSeen    DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  executions TaskExecution[]
  workflowExecutions WorkflowExecution[] @relation("WorkerToWorkflowExecutions")

  @@map("workers")
}

model Workflow {
  id          String   @id @default(uuid())
  name        String
  description String?
  scope       String   // ScopeType enum
  ownerId     String
  owner       User     @relation(fields: [ownerId], references: [id])
  version     Int      @default(1)
  
  // Graph definition (stored as JSON)
  nodes Json // WorkflowNode[]
  edges Json // WorkflowEdge[]
  
  scheduleId String?
  schedule   Schedule? @relation(fields: [scheduleId], references: [id])
  
  // New Scheduling System
  bindings   WorkflowScheduleBinding[]
  
  enabled    Boolean   @default(true)
  
  // Interface & Execution Logic
  inputVariables  Json? // Record<string, any>
  outputVariables Json? // Record<string, any>
  scheduling      Json? // { enabled: boolean, cron: string }
  notifications   Json? // any[]
  
  icon      String?
  tags      String[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  executions WorkflowExecution[]
  triggerTokens TriggerToken[]

  @@map("workflows")
}

model Schedule {
  id              String   @id @default(uuid())
  name            String   @unique
  description     String?
  scope           String   // ScopeType enum
  ownerId         String
  owner           User     @relation(fields: [ownerId], references: [id])
  
  // --- Old fields (Preserved for data safety) ---
  recurrenceType  String?   // RecurrenceType enum
  recurrenceValue Int?
  cronExpression  String?
  
  // --- New Spec Fields ---
  mode            String   @default("INTERVAL") // ONCE | INTERVAL | WEEKLY | MONTHLY | CRON
  payload         Json     @default("{}")       // Logic specific to the mode
  timezone        String   @default("UTC")      // Added for global customer support
  launchAt        DateTime?
  endAt           DateTime?
  maxRuns         Int?
  misfirePolicy   String   @default("fire_once") // skip | fire_once | catch_up_all
  coalesceSecs    Int      @default(60)
  
  enabled   Boolean  @default(true)
  state     String   @default("ACTIVE") // ACTIVE | PAUSED (Aligned with spec)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  workflows Workflow[] // Legacy relation
  bindings  WorkflowScheduleBinding[]

  @@map("schedules")
}

model Calendar {
  id              String   @id @default(uuid())
  name            String   @unique
  description     String?
  timezone        String   @default("UTC")
  state           String   @default("ACTIVE") // ACTIVE | PAUSED
  
  ownerId         String
  owner           User     @relation(fields: [ownerId], references: [id])
  
  rules           CalendarRule[]
  bindings        WorkflowScheduleBinding[]
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("calendars")
}

model CalendarRule {
  id           String   @id @default(uuid())
  calendarId   String
  calendar     Calendar @relation(fields: [calendarId], references: [id], onDelete: Cascade)
  
  ruleType     String   // ALLOW_WINDOW | EXCLUDE_WINDOW | EXCEPTION_DATE
  payload      Json     // Specific window/date data
  
  createdAt    DateTime @default(now())

  @@map("calendar_rules")
}

model WorkflowScheduleBinding {
  id               String   @id @default(uuid())
  workflowId       String
  workflow         Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  
  scheduleId       String
  schedule         Schedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  
  calendarId       String?
  calendar         Calendar? @relation(fields: [calendarId], references: [id])
  
  skipIfRunning    Boolean  @default(true)
  maxConcurrency   Int      @default(1)
  retryPolicy      Json?    // { maxAttempts, interval, strategy, jitter }
  
  state            String   @default("ACTIVE") // ACTIVE | PAUSED
  
  lastFiredAt      DateTime?
  nextFireAt       DateTime?
  
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  executions       WorkflowExecution[]

  @@map("workflow_schedule_bindings")
}

model WorkflowExecution {
  id              String   @id @default(uuid())
  workflowId      String
  workflow        Workflow @relation(fields: [workflowId], references: [id])
  workflowName    String
  workflowVersion Int
  
  bindingId     String?
  binding       WorkflowScheduleBinding? @relation(fields: [bindingId], references: [id])
  
  status        String   // ExecutionStatus enum
  triggeredBy   String   // SCHEDULE | MANUAL | SIGNAL
  triggeredByUser String?
  
  startedAt   DateTime
  completedAt DateTime?
  duration    Int?      // milliseconds
  
  // Task execution results (stored as JSON)
  taskExecutions Json // TaskExecutionResult[] - Consider phasing this out for the relation
  
  // Relations
  parentExecutionId String?
  parentExecution   WorkflowExecution? @relation("WorkflowExecutionsToWorkflowExecutions", fields: [parentExecutionId], references: [id])
  childExecutions   WorkflowExecution[] @relation("WorkflowExecutionsToWorkflowExecutions")

  parentTaskExecutionId String?
  parentTaskExecution   TaskExecution? @relation("TaskExecutionToSubWorkflow", fields: [parentTaskExecutionId], references: [id])

  sourceExecutionId     String?
  sourceExecution       WorkflowExecution? @relation("SourceToTriggeredExecutions", fields: [sourceExecutionId], references: [id])
  triggeredExecutions   WorkflowExecution[] @relation("SourceToTriggeredExecutions")

  targetWorkerId String?
  targetWorker   Worker? @relation("WorkerToWorkflowExecutions", fields: [targetWorkerId], references: [id])

  taskExecutionRecords TaskExecution[] @relation("WorkflowExecutionToTaskExecutions")

  createdAt DateTime @default(now())

  @@map("workflow_executions")
  @@index([workflowId])
  @@index([status])
  @@index([startedAt])
}

model SystemSetting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  description String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("system_settings")
}

model GlobalVariable {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  group       String?
  type        String   // string|number|boolean|array|object|binary|secret
  value       String   // Encrypted if type is secret
  validation  Json?    // regex|JSON schema|min|max|required
  isSecret    Boolean  @default(false)
  state       String   @default("ACTIVE") // ACTIVE|DEPRECATED|PENDING_REMOVAL
  version     Int      @default(1) // Optimistic concurrency
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("global_variables")
}

model TriggerToken {
  id          String   @id @default(uuid())
  token       String   @unique
  workflowId  String
  workflow    Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  
  description String?
  enabled     Boolean  @default(true)
  expiresAt   DateTime?
  
  // New field for webhook mapping
  mapping     Json     @default("{}") // SourcePath (body.x) -> WorkflowInputId
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("trigger_tokens")
}

model GlobalVariableGroup {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@map("global_variable_groups")
}

model AuditLog {
  id        String   @id @default(uuid())
  action    String   // CREATE|UPDATE|DELETE
  entity    String   // GLOBAL_VAR etc
  entityId  String
  actor     String   // username
  details   Json?    // Before/After, redacted
  createdAt DateTime @default(now())

  @@map("audit_logs")
}

model WebhookSample {
  id        String   @id @default(uuid())
  tokenId   String   @unique  // one active sample per token at a time
  body      Json
  headers   Json?
  query     Json?
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("webhook_samples")
}
